define i32 @main() {
entry:
  %v.0 = alloca i32
  store %v.0, 0
  %v.1 = alloca i32
  store %v.1, 0
  br label bb1
bb1:
  %v.2 = load %v.0
  %v.3 = icmp slt %v.2, 10
  cond_br %v.3, label bb2, label bb3
bb2:
  %v.4 = load %v.1
  %v.5 = load %v.0
  %v.6 = add %v.4, %v.5
  store %v.1, %v.6
  %v.7 = load %v.0
  %v.8 = add %v.7, 1
  store %v.0, %v.8
  br label bb1
bb3:
  %v.9 = load %v.1
  ret %v.9
}
